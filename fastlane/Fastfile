default_platform(:ios)

platform :ios do
  desc "Run release preflight checks"
  lane :preflight do
    sh "flutter pub get"
    sh "flutter analyze"
    sh "flutter test"
  end

  desc "Build a signed release IPA with explicit version/build numbers"
  lane :build_ipa do |options|
    version_name = options[:version_name] || ENV["IOS_VERSION_NAME"] || "1.0.0"
    build_number = options[:build_number] || ENV["IOS_BUILD_NUMBER"]

    UI.user_error!("Missing build number. Pass build_number:<n> or set IOS_BUILD_NUMBER.") unless build_number

    sh "flutter build ipa --release --build-name=#{version_name} --build-number=#{build_number}"
  end

  desc "Upload IPA to App Store Connect/TestFlight using API key"
  lane :upload_to_testflight do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"],
      duration: 1200,
      in_house: false
    )

    ipa_path = options[:ipa] || "build/ios/ipa/Runner.ipa"
    changelog = options[:changelog] || ENV["IOS_CHANGELOG"] || "Automated upload"

    pilot(
      api_key: api_key,
      ipa: ipa_path,
      changelog: changelog,
      skip_waiting_for_build_processing: false,
      distribute_external: false
    )
  end

  desc "Run preflight, build IPA, and upload to App Store Connect"
  lane :release do |options|
    preflight
    build_ipa(options)
    upload_to_testflight(options)
  end
end
